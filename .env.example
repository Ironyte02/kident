# Copy to .env and fill in. These are read by Vite at build time (VITE_ prefix
# = exposed to the browser, so only put publishable/anon values here).

# Supabase project
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"

# Web Push — PUBLIC VAPID key only. Generate a pair with:
#   npx web-push generate-vapid-keys
# Put the matching PRIVATE key in the Edge Function secrets, never here.
VITE_VAPID_PUBLIC_KEY=""
